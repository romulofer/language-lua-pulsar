{
  "name": "language-lua-pulsar",
  "version": "0.15.2",
  "private": false,
  "main": "lib/main",
  "description": "Lua language support for Pulsar: tree-sitter highlighting, snippets and folding (Lua 5.5, with Lua 5.1/LuaJIT compatibility).",
  "author": "Rômulo Fernandes Evangelista (https://github.com/romulofer)",
  "contributors": [
    "Jorge Garrido Oval (https://github.com/FireZenk)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/romulofer/language-lua-pulsar.git"
  },
  "homepage": "https://github.com/romulofer/language-lua-pulsar#readme",
  "bugs": {
    "url": "https://github.com/romulofer/language-lua-pulsar/issues"
  },
  "license": "MIT",
  "keywords": [
    "lua",
    "luajit",
    "grammar",
    "tree-sitter",
    "pulsar",
    "language"
  ],
  "engines": {
    "atom": "*",
    "node": ">=12"
  },
  "consumedServices": {
    "hyperlink.injection": {
      "versions": {
        "0.1.0": "consumeHyperlinkInjection"
      }
    },
    "todo.injection": {
      "versions": {
        "0.1.0": "consumeTodoInjection"
      }
    }
  },
  "dependencies": {}
